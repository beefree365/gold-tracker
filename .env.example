# Finnhub WebSocket Configuration (for real-time data)
FINNHUB_TOKEN=your_finnhub_token
FINNHUB_SYMBOL=OANDA:XAU_USD
FINNHUB_RECONNECT_DELAY_MS=3000

# Spot Symbol Configuration (optional, defaults to FINNHUB_SYMBOL)
SPOT_SYMBOL=OANDA:XAU_USD

# iTick WebSocket Configuration (RECOMMENDED for gold/forex)
ITICK_TOKEN=your_itick_token
ITICK_SYMBOL=XAUUSD
ITICK_WS_URL=wss://api-free.itick.org/forex

# TwelveData API Configuration (for k-line charts)
TWELVE_TOKEN=your_twelvedata_token
TWELVE_SYMBOL=XAU/USD

# Long Connection Protection (built-in, no config needed)
# - Heartbeat: Ping every 30 seconds to keep connection alive
# - Idle detection: Auto-reconnect if no messages for 2 minutes
# - Exponential backoff: 3s → 6s → 12s → 24s → ... (max 5 min)
# - Rate limit protection: Minimum 30s between reconnect attempts
# - Maximum reconnection attempts: 10 before giving up
